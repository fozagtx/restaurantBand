{
  "name": "restaura",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Restaura Band-powered restaurant visual outreach workflow.",
  "scripts": {
    "build": "tsc",
    "dev:agents": "tsx src/agents/runAgents.ts",
    "dev:pipeline": "tsx src/localPipeline.ts",
    "preflight": "tsx src/preflight.ts",
    "start": "node dist/railwayWorker.js",
    "start:agents": "node dist/agents/runAgents.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@band-ai/sdk": "^0.1.6",
    "dotenv": "^17.2.3",
    "js-yaml": "^4.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
