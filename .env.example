# Band Cloud defaults from the Band SDK docs. Only change these for self-hosted Band.
BAND_REST_URL=https://app.band.ai/
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
BAND_AGENT_API_KEY=

# Required for live restaurant research. The app never creates mock restaurant leads.
EXA_API_KEY=
EXA_NUM_RESULTS=12

# Required for all agent core chat/reasoning and the design agent's image/prompt model call.
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_CHAT_MODEL=Qwen/Qwen3-8B
FEATHERLESS_IMAGE_MODEL=BennyDaBall/Z-Image-Engineer-V6
FEATHERLESS_TEMPERATURE=0.7

# Required when sending the final digest to Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Band participant display names. Create remote agents with these names.
RESEARCH_AGENT_MENTION="@Lead Scout"
COPYWRITER_AGENT_MENTION="@Pitch Copywriter"
DESIGN_AGENT_MENTION="@Food Design Director"
# Required. Use the actual owner/agency sending the outreach.
AGENCY_NAME=
